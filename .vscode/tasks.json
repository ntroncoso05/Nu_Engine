// Configure tasks as build clean, etc.
{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Nu-Debug",
            "problemMatcher": [
                "$gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "args": [
                    "Debug"
                ],
                "command": "${workspaceFolder}/NuWin.bat"
            },
            "linux": {
                "sudo": true,
                "args": [
                    "Debug"
                ],
                "command": "${workspaceFolder}/NuLinux.sh"
            }
        },
        {
            "type": "shell",
            "label": "Nu-Release",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "windows": {
                "args": [
                    "Release"
                ],
                "command": "${workspaceFolder}/NuWin.bat"
            },
            "linux": {
                "sudo": true,
                "args": [
                    "Release"
                ],
                "command": "${workspaceFolder}/NuLinus.sh"
            }
        }
    ]
}